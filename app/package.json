{
	"name": "app",
	"private": true,
	"version": "0.1.5",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:apk": "vite build --mode capacitor",
		"build:apk-prod": "vite build --mode capacitor-prod",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/svelte": "^5.3.1",
		"@types/leaflet": "^1.9.21",
		"happy-dom": "^20.9.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.1",
		"@capacitor/app": "^8.1.0",
		"@capacitor/cli": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@capacitor/geolocation": "^8.2.0",
		"@capacitor/ios": "^8.3.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@tailwindcss/vite": "^4.2.2",
		"leaflet": "^1.9.4",
		"tailwindcss": "^4.2.2"
	}
}
