# Database
DB_NAME=muse
DB_USER=muse
DB_PASSWORD=muse_dev_password
DB_HOST=localhost
DB_PORT=5433

# Django
# In dev (DJANGO_DEBUG=1), settings.py falls back to a `django-insecure-`
# dev key if this is empty. In prod, missing key raises ImproperlyConfigured.
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS / CSRF (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5174

# Production HTTPS hardening — only consulted when DJANGO_DEBUG=0.
# Reverse proxy (nginx/Traefik) already terminates TLS, so SSL_REDIRECT
# stays off by default to avoid redirect loops.
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_HSTS_SECONDS=31536000

# Frontend
VITE_API_BASE_URL=http://localhost:8001/api/v1

# Google Places (server-side only, never expose to frontend)
GOOGLE_PLACES_API_KEY=

# Nominatim reverse-geocoding proxy. Required by their usage policy:
# https://operations.osmfoundation.org/policies/nominatim/
# - APP_CONTACT_EMAIL: real address you can be reached at if they spot abuse.
# - NOMINATIM_USER_AGENT: descriptive UA identifying the app + version.
APP_CONTACT_EMAIL=contact@lovemuse.app
NOMINATIM_USER_AGENT=muse/1.0 (+https://lovemuse.app)

# Email — fallback Django SMTP/console (NOT used for invitations anymore;
# kept for future ad-hoc mail or Django admin password resets).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Muse <no-reply@localhost>
APP_PUBLIC_URL=http://localhost:5174

# Resend (transactional email — invitations).
# Get a key at https://resend.com/api-keys (format: re_xxx...).
# Empty string disables sending and the service returns 503 to the caller.
# For testing without a verified domain, set DEFAULT_FROM_EMAIL above to
# "Muse <onboarding@resend.dev>" — that sandbox sender only delivers to
# the email registered on your Resend account.
RESEND_API_KEY=
