# Database
DB_NAME=muse
DB_USER=muse
DB_PASSWORD=muse_dev_password
DB_HOST=localhost
DB_PORT=5433

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5174

# Frontend
VITE_API_BASE_URL=http://localhost:8001/api/v1

# Google Places (server-side only, never expose to frontend)
GOOGLE_PLACES_API_KEY=

# Email (invitations). In dev, backend defaults to console output.
# In prod set SMTP details — otherwise invitations log errors silently.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Muse <no-reply@localhost>
APP_PUBLIC_URL=http://localhost:5174
